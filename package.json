{
  "name": "metalyceum",
  "version": "1.0.0",
  "description": "3D social event world with room-based YouTube Live and Google Meet sessions",
  "main": "src/index.ts",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "tsc --noEmit && wrangler deploy --minify",
    "typecheck": "tsc --noEmit",
    "typecheck:test": "tsc --noEmit -p test/tsconfig.json",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:trace": "playwright test --trace on",
    "test:e2e:report": "playwright show-report",
    "lint": "biome check .",
    "format": "biome check --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@cloudflare/workers-types": "^4.20240405.0",
    "@playwright/test": "^1.55.1",
    "@types/three": "^0.128.0",
    "@vitest/browser": "^4.1.7",
    "@vitest/browser-playwright": "^4.1.7",
    "cannon-es": "^0.20.0",
    "three": "^0.128.0",
    "typescript": "^5.4.5",
    "vitest": "^4.1.7",
    "wrangler": "^4.98.0"
  }
}
