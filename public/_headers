# Security headers for all static asset responses.
# Workers Static Assets serves files directly at the edge without invoking the
# Worker, so these header-only protections must live here rather than in code.
# (The Content-Security-Policy is delivered via a <meta> tag in index.html.)
/*
  X-Frame-Options: SAMEORIGIN
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin

# HTML entry point — always revalidate so deploys are picked up immediately.
/
  Cache-Control: no-cache

/index.html
  Cache-Control: no-cache

# JS modules and stylesheet — no-cache so deploys are visible immediately on next
# page load without a hard-refresh. The browser still reuses the cached response if
# the ETag/Last-Modified hasn't changed (conditional GET), so it stays fast.
/app.js
  Cache-Control: no-cache

/js/*
  Cache-Control: no-cache

/styles.css
  Cache-Control: no-cache

# MIDI files are large and change rarely — cache for a week.
/midi/*
  Cache-Control: public, max-age=604800, stale-while-revalidate=2592000
